---
import { Image } from "astro:assets";
import HeaderBackground from "../../../../public/Image/MarketingAgency/HeaderBackground.webp";
import MarketingAgencyLogo from "../../../../public/Image/MarketingAgency/MarketingAgencyLogo.webp";
import MobileMenu from "../../GlobalComponents/MobileMenu";
---

<div class="relative w-full">
  {/* Design less than 768px */}

  <Image
    src={HeaderBackground}
    alt=""
    class="absolute inset-0 object-cover w-full h-full"
    width={1920}
    height={1080}
    sizes="100vw"
    widths={[640, 1024, 1600, 1920]}
  />

  <div
    class="absolute bottom-0 left-0 flex flex-col items-center justify-center w-full h-full bg-black/60"
  >
  </div>

  <div
    class="relative z-10 grid items-center justify-center grid-cols-1 p-8 w-full h-dvh md:h-auto max-w-[100rem] m-auto"
  >
    <div
      class="flex flex-col items-center justify-center w-full gap-8 md:flex-row md:justify-between"
    >
      <Image
        src={MarketingAgencyLogo}
        alt="MarketingAgencyLogo"
        class="object-contain w-32 h-32 cursor-pointer invert-0"
        width={800}
        height={800}
      />

      <div
        class="flex flex-row items-center justify-center gap-4 text-center bg-slate-100 rounded-xl"
      >
        <MobileMenu
          textColor="text-zinc-700 transition-all duration-900 ease-out"
          hoverColor="hover:text-zinc-950"
          bgColor=""
          invertColor="text-black"
          client:load
        />
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-center gap-4 text-center md:h-dvh"
    >
      <h1
        class="w-full text-2xl md:text-4xl lg:text-7xl font-bold md:max-w-[50rem] md:mx-auto text-white"
      >
        Construye tu marca
      </h1>

      <p class="w-full max-w-xl text-lg text-white md:mx-auto">
        Diseño creativo galardonado centrado en una mayor exposición de la
        marca.
      </p>

      <button
        class="w-full text-lg p-2 font-bold text-black transition-all duration-700 ease-out bg-slate-100 rounded-xl max-w-[20rem] hover:bg-slate-300"
      >
        Empieza hoy
      </button>
    </div>
  </div>
</div>
