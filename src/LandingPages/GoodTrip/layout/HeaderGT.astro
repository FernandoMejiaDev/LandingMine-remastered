---
import { Image } from "astro:assets";
import GoodTripB from "../../../../public/Image/GoodTrip/GoodTripB.webp";
import GoodTripLogo from "../../../../public/Image/GoodTrip/GoodTripLogo.webp";
import MobileMenu from "../../GlobalComponents/MobileMenu";
import DarkMode from "../../GlobalComponents/DarkMode";
---

<div class="relative w-full h-dvh">
  <Image
    src={GoodTripB}
    alt="alt"
    class="absolute inset-0 object-cover w-full h-full"
    width={1920}
    height={1080}
    sizes="100vw"
    widths={[640, 1024, 1600, 1920]}
  />

  <div
    class="absolute bottom-0 left-0 flex flex-col items-center justify-center w-full h-full bg-black/60"
  >
  </div>

  <div
    class="relative flex flex-col px-8 py-12 items-center h-full justify-between w-full m-auto max-w-[100rem]"
  >
    <div
      class="grid items-center justify-center w-full h-auto grid-cols-2 gap-4 md:max-h-40 md:grid-cols-3"
    >
      <div class="flex justify-start">
        <Image
          src={GoodTripLogo}
          alt="GoodTripLogo"
          class="object-contain w-40 h-auto cursor-pointer md:order-1"
          width={800}
          height={800}
        />
      </div>

      <div
        class="hidden md:flex items-center justify-center bg-black/20 md:bg-transparent md:backdrop-blur-[0px] backdrop-blur-[2px] rounded-lg"
      >
        <MobileMenu
          textColor="text-slate-100 transition-all duration-900 ease-out"
          hoverColor="hover:text-slate-300"
          bgColor=""
          invertColor="text-white"
          client:load
        />
      </div>

      <div class="flex justify-end">
        <DarkMode bgColor="text-slate-100" client:load />
      </div>

      <div
        class="md:hidden w-fit mx-auto col-span-2 border-white border-2 backdrop-blur-[4px] rounded-lg"
      >
        <MobileMenu
          textColor="text-slate-100 transition-all duration-900 ease-out"
          hoverColor="hover:text-slate-300"
          bgColor=""
          invertColor="text-white"
          client:load
        />
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-center max-w-3xl gap-2 mx-auto text-center text-white md:flex-1"
    >
      <h1 class="text-2xl font-bold leading-tight md:text-4xl xl:text-6xl">
        Descubre el mundo con <span class="text-sky-400">GoodTrip</span>
      </h1>

      <p class="max-w-2xl text-base md:text-lg text-slate-200">
        Vive experiencias inolvidables, explora destinos únicos y deja que
        nosotros planifiquemos el viaje de tus sueños.
      </p>

      <div class="flex gap-4 mt-4">
        <button
          class="p-2 font-bold text-white transition-all duration-300 rounded-xl bg-sky-400 hover:bg-sky-600"
        >
          Explorar Destinos
        </button>
        <button
          class="p-2 font-bold transition-all duration-300 border border-white rounded-xl hover:bg-white hover:text-black"
        >
          Planifica tu Viaje button
        </button>
      </div>
    </div>
  </div>
</div>
