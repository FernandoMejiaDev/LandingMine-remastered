---
import { Image } from "astro:assets";
import Background from "../../../../public/Image/Morgana/Background.webp";
import MorganaLogo from "../../../../public/Image/Morgana/MorganaLogo.webp";
import MobileMenu from "../../GlobalComponents/MobileMenu";
import DarkMode from "../../GlobalComponents/DarkMode";
import Search from "../assets/svg/Search";
---

<div class="relative w-full h-dvh">
  <Image
    src={Background}
    alt="alt"
    class="absolute inset-0 flex flex-col object-cover object-center w-full h-full object-fixed"
    width={1920}
    height={1080}
    sizes="100vw"
    widths={[640, 1024, 1600, 1920]}
  />

  <div
    class="absolute bottom-0 left-0 flex flex-col items-center justify-center w-full h-full bg-black/60"
  >
  </div>

  <div
    class="relative text-slate-100 flex flex-col px-8 py-8 items-center h-full justify-between w-full m-auto max-w-[100rem]"
  >
    <div
      class="grid items-center justify-center w-full h-auto grid-cols-3 gap-4 md:hidden"
    >
      <div class="flex justify-start order-1 md:justify-center">
        <Image
          src={MorganaLogo}
          alt="MorganaLogo"
          class="object-contain w-40 h-auto cursor-pointer invert"
          width={800}
          height={800}
        />
      </div>

      <div class="flex justify-center order-3">
        <DarkMode bgColor="text-slate-100" client:load />
      </div>

      <div class="relative flex justify-center order-2 w-full m-auto md:hidden">
        <input
          type="text"
          placeholder="Buscar..."
          class="p-4 backdrop-blur-[4px] w-full m-auto border-slate-100 rounded-lg bg-transparent border-2 text-slate-100 flex flex-row justify-between"
        />

        <div
          class="absolute transform -translate-y-1/2 text-slate-100 top-1/2 right-3"
        >
          <Search width="20" height="20" />
        </div>
      </div>

      <div
        class="md:hidden w-fit mx-auto order-4 col-span-3 border-slate-100 border-2 backdrop-blur-[4px] rounded-lg"
      >
        <MobileMenu
          textColor="text-slate-100 transition-all duration-900 ease-out"
          hoverColor="hover:text-slate-400"
          bgColor=""
          invertColor="text-white"
          client:load
        />
      </div>
    </div>

    <!-- md -->

    <div
      class="flex-row items-start justify-between hidden w-full gap-6 md:flex"
    >
      <div class="flex flex-row gap-6">
        <div class="flex justify-start">
          <Image
            src={MorganaLogo}
            alt="MorganaLogo"
            class="object-contain w-40 h-auto cursor-pointer invert"
            width={800}
            height={800}
          />
        </div>

        <div class="">
          <MobileMenu
            textColor="text-slate-100 transition-all duration-900 ease-out"
            hoverColor="hover:text-slate-400"
            bgColor=""
            invertColor="text-white"
            client:load
          />
        </div>
      </div>

      <div class="flex flex-row gap-6">
        <div class="relative w-full">
          <input
            type="text"
            placeholder="Buscar..."
            class="p-4 backdrop-blur-[4px] w-full m-auto border-slate-100 rounded-lg bg-transparent border-2 text-slate-100 flex flex-row justify-between"
          />

          <div
            class="absolute transform -translate-y-1/2 text-slate-100 top-1/2 right-3"
          >
            <Search width="20" height="20" />
          </div>
        </div>

        <div class="flex justify-end">
          <DarkMode bgColor="text-slate-100" client:load />
        </div>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-center w-full max-w-3xl gap-2 mx-auto text-start md:flex-1"
    >
      <h1 class="text-3xl font-bold text-center md:text-6xl">
        Maneja con confianza, maneja con Morgana
      </h1>

      <p class="text-sm md:text-base text-center">
        Ya sea que busques comprar el auto de tus sueños o rentar uno para una
        ocasión especial, en <span class="font-bold">Morgana</span> encontrarás variedad,
        precios competitivos y un servicio excepcional. Nos apasiona ayudarte a encontrar
        el vehículo perfecto para cada etapa de tu vida.
      </p>
    </div>
  </div>
</div>
